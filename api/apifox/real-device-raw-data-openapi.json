  "components": {
    "schemas": {
      "ResultVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "nullable": true
          }
        }
      },
      "ResultObject": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "ResultArray": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "SensorQueryRequest": {
        "type": "object",
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "VW-CH01"
          },
          "limit": {
            "type": "integer",
            "example": 10
          }
        }
      },
      "HistoryQueryRequest": {
        "type": "object",
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "VW-CH01"
          },
          "startTime": {
            "type": "string",
            "example": "2026-05-09 00:00:00"
          },
          "endTime": {
            "type": "string",
            "example": "2026-05-09 23:59:59"
          },
          "limit": {
            "type": "integer",
            "example": 10
          }
        }
      },
      "VibratingWireUploadRequest": {
        "type": "object",
        "properties": {
          "sensorId": { "type": "string", "example": "VW-CH01" },
          "deviceNo": { "type": "string", "example": "0519" },
          "devType": { "type": "string", "example": "000A" },
          "channelNo": { "type": "integer", "example": 1 },
          "collectOption": { "type": "string", "example": "7F" },
          "sensorStatus": { "type": "integer", "example": 0 },
          "frequencyStatus": { "type": "integer", "example": 0 },
          "temperatureStatus": { "type": "integer", "example": 0 },
          "frequency": { "type": "number", "example": 1502.36 },
          "amplitude": { "type": "number", "example": 42.51 },
          "temperature": { "type": "number", "example": 26.8 },
          "sensorNo": { "type": "string", "example": "00000001" },
          "rawHex": { "type": "string", "example": "000A051981017F0044BC6637442ABB86419F800000000000083CFD" },
          "collectTime": { "type": "string", "example": "2026-05-09 23:01:00" }
        }
      },
      "FiberUploadRequest": {
        "type": "object",
        "properties": {
          "sensorId": { "type": "string", "example": "FBG-CH01" },
          "deviceNo": { "type": "string", "example": "OS-265" },
          "fiberNo": { "type": "string", "example": "OS-265" },
          "channelNo": { "type": "integer", "example": 1 },
          "wavelengthShift": { "type": "number", "example": 1532.123 },
          "intensity": { "type": "number", "example": 123.4 },
          "rawValue": { "type": "number", "example": 1532.123 },
          "wavelength": { "type": "number", "example": 1532.123 },
          "physicalValue": { "type": "number", "example": 12.35 },
          "unit": { "type": "string", "example": "microstrain" },
          "dataType": { "type": "string", "example": "STRAIN" },
          "rawPayload": { "type": "string", "example": "CH1,1532.123,12.35" },
          "collectTime": { "type": "string", "example": "2026-05-09 23:02:00" }
        }
      },
      "VibrationDatUploadRequest": {
        "type": "object",
        "properties": {
          "sensorId": { "type": "string", "example": "VD-CH01" },
          "deviceNo": { "type": "string", "example": "1305" },
          "filePath": { "type": "string", "example": "D:/data/vibration_20260509_230300.dat" },
          "channelNo": { "type": "integer", "example": 1 },
          "fileName": { "type": "string", "example": "vibration_20260509_230300.dat" },
          "fileSize": { "type": "integer", "example": 2048 },
          "version": { "type": "integer", "example": 1 },
          "sampleFreq": { "type": "number", "example": 1000.0 },
          "filterFreq": { "type": "number", "example": 200.0 },
          "gainAmplifier": { "type": "integer", "example": 1 },
          "triggerType": { "type": "integer", "example": 4 },
          "dataLength": { "type": "integer", "example": 4000 },
          "dataCount": { "type": "integer", "example": 1000 },
          "rawContent": { "type": "string", "example": "base64-or-raw-content-placeholder" },
          "dataJson": { "type": "string", "example": "[0.012,0.018,0.015,0.009]" },
          "collectTime": { "type": "string", "example": "2026-05-09 23:03:00" }
        }
      }
