{
  "openapi": "3.0.3",
  "info": {
    "title": "Ansteel SHM Real Device Raw Data API",
    "version": "1.0.0",
    "description": "Real-device raw data access preparation for an industrial structural health monitoring prototype."
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [
    {
      "name": "vibrating-wire"
    },
    {
      "name": "fiber"
    },
    {
      "name": "vibration-dat"
    }
  ],
  "paths": {
    "/api/sensor/vibrating-wire/raw/upload": {
      "post": {
        "summary": "Upload vibrating-wire raw data",
        "operationId": "uploadVibratingWireRawData",
        "tags": [
          "vibrating-wire"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VibratingWireUploadRequest"
              },
              "examples": {
                "default": {
                  "value": {
                    "sensorId": "VW-CH01",
                    "deviceNo": "0519",
                    "devType": "000A",
                    "channelNo": 1,
                    "collectOption": "7F",
                    "sensorStatus": 0,
                    "frequencyStatus": 0,
                    "temperatureStatus": 0,
                    "frequency": 1502.36,
                    "amplitude": 42.51,
                    "temperature": 26.8,
                    "sensorNo": "00000001",
                    "rawHex": "000A051981017F0044BC6637442ABB86419F800000000000083CFD",
                    "collectTime": "2026-05-09 23:01:00"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": null
                }
              }
            }
          }
        }
      }
    },
    "/api/data/vibrating-wire/latest": {
      "post": {
        "summary": "Query latest vibrating-wire raw data",
        "operationId": "getLatestVibratingWireRawData",
        "tags": [
          "vibrating-wire"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SensorQueryRequest"
              },
              "examples": {
                "default": {
                  "value": {
                    "sensorId": "VW-CH01",
                    "limit": 10
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultObject"
                },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": {}
                }
              }
            }
          }
        }
      }
    },
    "/api/data/vibrating-wire/history": {
      "post": {
        "summary": "Query vibrating-wire raw data history",
        "operationId": "getVibratingWireRawDataHistory",
        "tags": [
          "vibrating-wire"
