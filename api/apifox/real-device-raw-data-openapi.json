    "/api/sensor/vibration-dat/raw/upload": {
      "post": {
        "summary": "Upload vibration DAT raw file metadata",
        "operationId": "uploadVibrationDatRawData",
        "tags": [
          "vibration-dat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VibrationDatUploadRequest"
              },
              "examples": {
                "default": {
                  "value": {
                    "sensorId": "VD-CH01",
                    "deviceNo": "1305",
                    "filePath": "D:/data/vibration_20260509_230300.dat",
                    "channelNo": 1,
                    "fileName": "vibration_20260509_230300.dat",
                    "fileSize": 2048,
                    "version": 1,
                    "sampleFreq": 1000.0,
                    "filterFreq": 200.0,
                    "gainAmplifier": 1,
                    "triggerType": 4,
                    "dataLength": 4000,
                    "dataCount": 1000,
                    "rawContent": "base64-or-raw-content-placeholder",
                    "dataJson": "[0.012,0.018,0.015,0.009]",
                    "collectTime": "2026-05-09 23:03:00"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
