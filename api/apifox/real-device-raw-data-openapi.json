        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HistoryQueryRequest"
              },
              "examples": {
                "default": {
                  "value": {
                    "sensorId": "VW-CH01",
                    "startTime": "2026-05-09 00:00:00",
                    "endTime": "2026-05-09 23:59:59",
                    "limit": 10
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultArray"
                },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": []
                }
              }
            }
          }
        }
      }
    },
