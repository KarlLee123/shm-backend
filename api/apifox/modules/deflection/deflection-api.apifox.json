{
  "openapi": "3.0.3",
  "info": {
    "title": "Ansteel SHM - Deflection Module API",
    "version": "1.0.0",
    "description": "Deflection 模块分离终稿。仅服务于挠度模块，不含 stress 字段。"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Deflection",
      "description": "挠度模块"
    }
  ],
  "paths": {
    "/api/sensor/deflection/raw/upload": {
      "post": {
        "tags": [
          "Deflection"
        ],
        "summary": "原始数据上传",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeflectionRawUploadDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/sensor/deflection/result/upload": {
      "post": {
        "tags": [
          "Deflection"
        ],
        "summary": "结果回写",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeflectionResultUploadDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/data/deflection/verify": {
      "post": {
        "tags": [
          "Deflection"
        ],
        "summary": "人工核验",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeflectionVerifyDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/data/deflection/latest": {
      "post": {
        "tags": [
          "Deflection"
        ],
        "summary": "查询最新核验通过数据",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeflectionQueryDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeflectionLatestResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/data/deflection/history": {
      "post": {
        "tags": [
          "Deflection"
        ],
        "summary": "查询历史核验通过数据",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeflectionQueryDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeflectionHistoryResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DeflectionRawUploadDTO": {
        "type": "object",
        "required": [
          "sensorId",
          "displacementValue",
          "collectTime"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "D001"
          },
          "displacementValue": {
            "type": "number",
            "example": 3.42
          },
          "collectTime": {
            "type": "string",
            "example": "2026-04-20 14:30:00"
          }
        }
      },
      "DeflectionResultUploadDTO": {
        "type": "object",
        "required": [
          "sensorId",
          "calcDeflection",
          "collectTime"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "D001"
          },
          "calcDeflection": {
            "type": "number",
            "example": 12.56
          },
          "collectTime": {
            "type": "string",
            "example": "2026-04-20 14:30:00"
          },
          "calcTime": {
            "type": "string",
            "example": "2026-04-20 14:30:05"
          }
        }
      },
      "DeflectionVerifyDTO": {
        "type": "object",
        "required": [
          "sensorId",
          "action",
          "collectTime"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "D001"
          },
          "action": {
            "type": "string",
            "example": "PASS"
          },
          "verifiedDeflection": {
            "type": "number",
            "example": 12.4
          },
          "verifyRemark": {
            "type": "string",
            "example": "挠度结果异常，要求重新计算"
          },
          "collectTime": {
            "type": "string",
            "example": "2026-04-20 14:30:00"
          },
          "verifyTime": {
            "type": "string",
            "example": "2026-04-20 14:31:00"
          }
        }
      },
      "DeflectionQueryDTO": {
        "type": "object",
        "required": [
          "sensorId"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "D001"
          },
          "startTime": {
            "type": "string",
            "example": "2026-04-20 00:00:00"
          },
          "endTime": {
            "type": "string",
            "example": "2026-04-20 23:59:59"
          },
          "limit": {
            "type": "integer",
            "example": 100
          }
        }
      },
      "DeflectionMonitorVO": {
        "type": "object",
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "D001"
          },
          "displacementValue": {
            "type": "number",
            "example": 3.42
          },
          "calcDeflection": {
            "type": "number",
            "example": 12.56
          },
          "verifiedDeflection": {
            "type": "number",
            "example": 12.4
          },
          "verifyStatus": {
            "type": "integer",
            "example": 2
          },
          "verifyRemark": {
            "type": "string",
            "nullable": true
          },
          "collectTime": {
            "type": "string",
            "example": "2026-04-20 14:30:00"
          },
          "calcTime": {
            "type": "string",
            "example": "2026-04-20 14:30:05"
          },
          "verifyTime": {
            "type": "string",
            "example": "2026-04-20 14:31:00"
          }
        }
      },
      "ResultVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "nullable": true
          }
        }
      },
      "DeflectionLatestResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/DeflectionMonitorVO"
          }
        }
      },
      "DeflectionHistoryResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeflectionMonitorVO"
            }
          }
        }
      }
    }
  }
}