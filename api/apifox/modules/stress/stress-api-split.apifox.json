{
  "openapi": "3.0.3",
  "info": {
    "title": "Ansteel SHM - Stress Module API",
    "version": "2.0.0",
    "description": "Stress 模块分离终稿。仅服务于应力模块，不含 deflection 字段。"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Stress",
      "description": "应力模块"
    }
  ],
  "paths": {
    "/api/sensor/stress/raw/upload": {
      "post": {
        "tags": [
          "Stress"
        ],
        "summary": "原始数据上传",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StressRawUploadDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/sensor/stress/result/upload": {
      "post": {
        "tags": [
          "Stress"
        ],
        "summary": "结果回写",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StressResultUploadDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/data/stress/verify": {
      "post": {
        "tags": [
          "Stress"
        ],
        "summary": "人工核验",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StressVerifyDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/data/stress/latest": {
      "post": {
        "tags": [
          "Stress"
        ],
        "summary": "查询最新核验通过数据",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StressQueryDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StressLatestResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/data/stress/history": {
      "post": {
        "tags": [
          "Stress"
        ],
        "summary": "查询历史核验通过数据",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StressQueryDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StressHistoryResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StressRawUploadDTO": {
        "type": "object",
        "required": [
          "sensorId",
          "forceValue",
          "displacementValue",
          "collectTime"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "S001"
          },
          "forceValue": {
            "type": "number",
            "example": 125.6
          },
          "displacementValue": {
            "type": "number",
            "example": 3.42
          },
          "collectTime": {
            "type": "string",
            "example": "2026-04-20 14:30:00"
          }
        }
      },
      "StressResultUploadDTO": {
        "type": "object",
        "required": [
          "sensorId",
          "calcStress",
          "collectTime"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "S001"
          },
          "calcStress": {
            "type": "number",
            "example": 98.56
          },
          "collectTime": {
            "type": "string",
            "example": "2026-04-20 14:30:00"
          },
          "calcTime": {
            "type": "string",
            "example": "2026-04-20 14:30:05"
          }
        }
      },
      "StressVerifyDTO": {
        "type": "object",
        "required": [
          "sensorId",
          "action",
          "collectTime"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "S001"
          },
          "action": {
            "type": "string",
            "example": "PASS"
          },
          "verifiedStress": {
            "type": "number",
            "example": 98.4
          },
          "verifyRemark": {
            "type": "string",
            "example": "应力结果异常，要求重新计算"
          },
          "collectTime": {
            "type": "string",
            "example": "2026-04-20 14:30:00"
          },
          "verifyTime": {
            "type": "string",
            "example": "2026-04-20 14:31:00"
          }
        }
      },
      "StressQueryDTO": {
        "type": "object",
        "required": [
          "sensorId"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "S001"
          },
          "startTime": {
            "type": "string",
            "example": "2026-04-20 00:00:00"
          },
          "endTime": {
            "type": "string",
            "example": "2026-04-20 23:59:59"
          },
          "limit": {
            "type": "integer",
            "example": 100
          }
        }
      },
      "StressMonitorVO": {
        "type": "object",
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "S001"
          },
          "forceValue": {
            "type": "number",
            "example": 125.6
          },
          "displacementValue": {
            "type": "number",
            "example": 3.42
          },
          "calcStress": {
            "type": "number",
            "example": 98.56
          },
          "verifiedStress": {
            "type": "number",
            "example": 98.4
          },
          "verifyStatus": {
            "type": "integer",
            "example": 2
          },
          "verifyRemark": {
            "type": "string",
            "nullable": true
          },
          "collectTime": {
            "type": "string",
            "example": "2026-04-20 14:30:00"
          },
          "calcTime": {
            "type": "string",
            "example": "2026-04-20 14:30:05"
          },
          "verifyTime": {
            "type": "string",
            "example": "2026-04-20 14:31:00"
          }
        }
      },
      "ResultVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "nullable": true
          }
        }
      },
      "StressLatestResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/StressMonitorVO"
          }
        }
      },
      "StressHistoryResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StressMonitorVO"
            }
          }
        }
      }
    }
  }
}