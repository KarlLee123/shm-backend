{
  "openapi": "3.0.3",
  "info": {
    "title": "Ansteel SHM - Displacement Module API",
    "version": "1.0.0",
    "description": "位移模块联调最终版（可导入 APIFox）。\n\n已按当前直采实时模块字段对齐：DisplacementUploadDTO / DisplacementQueryDTO。\n模块目标：上传原始数据 -> 查询 latest -> 查询 history。"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Displacement",
      "description": "位移模块"
    }
  ],
  "paths": {
    "/api/sensor/displacement/upload": {
      "post": {
        "tags": [
          "Displacement"
        ],
        "summary": "原始位移数据上传",
        "description": "接收传感器/设备上传的原始数据，写入 displacement_data。",
        "operationId": "uploadDisplacementRawData",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DisplacementUploadDTO"
              },
              "examples": {
                "normal": {
                  "summary": "正常上传",
                  "value": {
                    "sensorId": "SENSOR_001",
                    "displacementValue": 12.34,
                    "collectTime": "2026-04-18 14:30:00"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "上传成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericSuccessResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "code": 200,
                      "message": "success",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "服务端错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/data/displacement/latest": {
      "post": {
        "tags": [
          "Displacement"
        ],
        "summary": "查询最新位移数据",
        "description": "根据 sensorId 查询指定传感器最新一条数据。",
        "operationId": "getLatestDisplacementData",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DisplacementLatestQueryDTO"
              },
              "examples": {
                "bySensor": {
                  "summary": "按传感器查询",
                  "value": {
                    "sensorId": "SENSOR_001"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DisplacementLatestResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "code": 200,
                      "message": "success",
                      "data": {
                        "sensorId": "SENSOR_001",
                        "displacementValue": 12.34,
                        "collectTime": "2026-04-18 14:30:00"
                      }
                    }
                  },
                  "empty": {
                    "value": {
                      "code": 200,
                      "message": "success",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "服务端错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/data/displacement/history": {
      "post": {
        "tags": [
          "Displacement"
        ],
        "summary": "查询位移历史数据",
        "description": "根据 sensorId + 时间范围查询历史数据列表。",
        "operationId": "getDisplacementHistoryData",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DisplacementHistoryQueryDTO"
              },
              "examples": {
                "normal": {
                  "summary": "正常历史查询",
                  "value": {
                    "sensorId": "SENSOR_001",
                    "startTime": "2026-04-18 00:00:00",
                    "endTime": "2026-04-18 23:59:59",
                    "limit": 100
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DisplacementHistoryResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "code": 200,
                      "message": "success",
                      "data": [
                        {
                          "sensorId": "SENSOR_001",
                          "displacementValue": 12.34,
                          "collectTime": "2026-04-18 14:30:00"
                        },
                        {
                          "sensorId": "SENSOR_001",
                          "displacementValue": 12.84,
                          "collectTime": "2026-04-18 15:00:00"
                        }
                      ]
                    }
                  },
                  "empty": {
                    "value": {
                      "code": 200,
                      "message": "success",
                      "data": []
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "服务端错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DisplacementUploadDTO": {
        "type": "object",
        "required": [
          "sensorId",
          "displacementValue",
          "collectTime"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "description": "传感器ID",
            "example": "SENSOR_001"
          },
          "displacementValue": {
            "type": "number",
            "description": "位移值",
            "example": 12.34
          },
          "collectTime": {
            "type": "string",
            "description": "采集时间，格式固定 yyyy-MM-dd HH:mm:ss",
            "example": "2026-04-18 14:30:00"
          }
        }
      },
      "DisplacementLatestQueryDTO": {
        "type": "object",
        "required": [
          "sensorId"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "description": "传感器ID",
            "example": "SENSOR_001"
          }
        }
      },
      "DisplacementHistoryQueryDTO": {
        "type": "object",
        "required": [
          "sensorId"
        ],
        "properties": {
          "sensorId": {
            "type": "string",
            "description": "传感器ID",
            "example": "SENSOR_001"
          },
          "startTime": {
            "type": "string",
            "description": "开始时间，格式固定 yyyy-MM-dd HH:mm:ss",
            "example": "2026-04-18 00:00:00"
          },
          "endTime": {
            "type": "string",
            "description": "结束时间，格式固定 yyyy-MM-dd HH:mm:ss",
            "example": "2026-04-18 23:59:59"
          },
          "limit": {
            "type": "integer",
            "description": "返回条数限制，后端会做兜底和截断",
            "example": 100,
            "minimum": 1
          }
        }
      },
      "DisplacementRawVO": {
        "type": "object",
        "properties": {
          "sensorId": {
            "type": "string",
            "example": "SENSOR_001"
          },
          "displacementValue": {
            "type": "number",
            "example": 12.34
          },
          "collectTime": {
            "type": "string",
            "example": "2026-04-18 14:30:00"
          }
        }
      },
      "GenericSuccessResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {}
        }
      },
      "GenericErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 500
          },
          "message": {
            "type": "string",
            "example": "failed"
          },
          "data": {
            "nullable": true
          }
        }
      },
      "DisplacementLatestResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/DisplacementRawVO"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "DisplacementHistoryResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DisplacementRawVO"
            }
          }
        }
      }
    }
  }
}